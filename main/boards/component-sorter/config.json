{
    "target": "esp32s3",
    "builds": [
        {
            "name": "component-sorter",
            "sdkconfig_append": [
                "CONFIG_BOARD_TYPE_COMPONENT_SORTER=y",
                "CONFIG_USE_WAKE_WORD_DETECT=n",
                "CONFIG_USE_AUDIO_PROCESSOR=n",
                "CONFIG_USE_REALTIME_CHAT=n",
                "CONFIG_USE_WECHAT_MESSAGE_STYLE=n",
                "CONFIG_CONNECTION_TYPE_WEBSOCKET=y",
                "CONFIG_WEBSOCKET_URL=\"ws://192.168.1.1:8080/ws/\"",
                "CONFIG_WEBSOCKET_ACCESS_TOKEN=\"component-sorter\""
            ]
        }
    ]
}
